{
  "name": "Cup Prediction",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/football-cup-prediction",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "mounts": ["source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume"],
  // Postgres is NOT forwarded here: it's a separate compose service exposed to
  // the host via docker-compose `ports: 5440:5432`. Forwarding it would bind a
  // dead 127.0.0.1:5440 listener that shadows the real published port.
  "forwardPorts": [3010],
  "portsAttributes": {
    "3010": {
      "label": "Next.js dev server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "sudo chown -R node:node /home/node/.claude && ([ -f /home/node/.claude.json ] || echo '{\"hasCompletedOnboarding\":true,\"theme\":\"dark\"}' > /home/node/.claude.json) && sudo corepack enable && sudo corepack prepare pnpm@10.30.3 --activate && pnpm install && npx playwright install --with-deps chromium && npx --yes --package @playwright/mcp@latest -- playwright install chromium",
  "updateContentCommand": "sudo chown node:node /workspaces/football-cup-prediction/node_modules && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-playwright.playwright",
        "vitest.explorer"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "containerEnv": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "GIT_TERMINAL_PROMPT": "0",
    "SSH_AUTH_SOCK": "",
    "GIT_ASKPASS": "/bin/false",
    "GITHUB_TOKEN": "",
    "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}"
  },
  "remoteUser": "node"
}
