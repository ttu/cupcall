# Copy to .env.local and fill in. Validated at startup by apps/web/src/shared/env.ts.

# PostgreSQL connection string (any provider — Neon recommended).
DATABASE_URL=postgres://user:password@host:5432/cup_prediction

# Auth.js session secret (generate: `openssl rand -base64 32`).
AUTH_SECRET=replace-me-with-a-32+-char-random-secret

# App base URL (used by Auth.js for callback/magic-link URLs).
# Dev server runs on a non-default port (3010) to avoid local project clashes.
AUTH_URL=http://localhost:3010

# Resend API key for sending magic-link emails (https://resend.com).
RESEND_API_KEY=re_replace_me
