{
  "mcpServers": {
    "postgres": {
      "command": "bash",
      "args": ["-c", "npx -y @modelcontextprotocol/server-postgres \"$PROD_DATABASE_URL\""]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "chromium",
        "--no-sandbox",
        "--isolated"
      ],
      "env": {
        "NODE_OPTIONS": ""
      }
    }
  }
}
