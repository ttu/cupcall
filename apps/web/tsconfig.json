{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "declaration": false,
    "noEmit": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "dom", "dom.iterable"],
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
