{
  "name": "cup-prediction",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "duplication": "jscpd .",
    "knip": "knip",
    "depcruise": "depcruise apps/web/src packages/*/src scripts --config .dependency-cruiser.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b && pnpm -C apps/web typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "sync": "TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/sync.ts",
    "backfill-finish-score-team-ids": "TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/backfill-finish-score-team-ids.ts",
    "seed": "TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/seed.ts",
    "seed:fresh": "bash scripts/db-reset.sh && TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/seed.ts",
    "seed:ongoing": "TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/seed-ongoing.ts",
    "seed:fresh:ongoing": "bash scripts/db-reset.sh && TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/seed-ongoing.ts",
    "seed:current": "TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/seed-current.ts",
    "seed:fresh:current": "bash scripts/db-reset.sh && TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/seed-current.ts",
    "seed:e2e": "TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/seed-e2e.ts",
    "db:migrate": "pnpm -C packages/db exec drizzle-kit migrate",
    "db:reset": "bash scripts/db-reset.sh",
    "dev": "bash scripts/dev.sh",
    "dev:trace": "OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 bash scripts/dev.sh",
    "jaeger": "docker compose -f docker-compose.jaeger.yml up",
    "e2e": "pnpm -C apps/web run e2e"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-sonarjs": "^4.2.0",
    "husky": "^9.0.0",
    "jscpd": "^5.0.12",
    "knip": "^6.27.0",
    "lint-staged": "^15.0.0",
    "pino": "^10.3.1",
    "prettier": "^3.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "data/**/{results,tournament}.json": [
      "env TSX_TSCONFIG_PATH=scripts/tsconfig.json pnpm exec tsx scripts/validate-data.ts"
    ]
  }
}
